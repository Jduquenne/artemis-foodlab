{
  "_schema": {
    "database": "CipeDatabase",
    "version": 10,
    "note": "Les créneaux de planning VIDES n'ont pas de record — leur absence dans la table = créneau libre. Les articles ménagers NON vérifiés n'ont pas de record non plus.",
    "tables": {
      "planning": {
        "primaryKey": "id",
        "indexes": ["[year+week]", "year", "week"],
        "idFormat": "{year}-W{week}-{day}-{slot}",
        "fields": {
          "id":        "string  — '{year}-W{week}-{day}-{slot}'",
          "day":       "string  — 'lundi' | 'mardi' | 'mercredi' | 'jeudi' | 'vendredi' | 'samedi' | 'dimanche'",
          "slot":      "string  — 'breakfast' | 'lunch' | 'snack' | 'dinner'",
          "recipeIds":  "string[] — tableau d'ids recette (ex: ['wm-001']). Plusieurs = multi-repas.",
          "dessertIds": "string[]? — ids recettes ingredient (max 3), uniquement pour lunch et dinner",
          "year":      "number  — ex: 2026",
          "week":      "number  — numéro de semaine ISO (1-53)",
          "persons":   "number? — absent = utilise defaultPortions de la recette"
        }
      },
      "household": {
        "primaryKey": "id",
        "indexes": [],
        "fields": {
          "id":            "string — même id que dans household-db.json (ex: 'hh-014')",
          "lastCheckedAt": "string — timestamp ISO 8601 (ex: '2026-03-01T10:32:00.000Z')"
        }
      },
      "freezerCategories": {
        "primaryKey": "id",
        "indexes": ["position"],
        "fields": {
          "id":       "string — uuid généré",
          "name":     "string — nom affiché de la catégorie",
          "position": "number — ordre d'affichage (0-based)",
          "items":    "FreezerItem[] — tableau mixte de FoodFreezerItem et BatchFreezerItem",
          "_FoodFreezerItem": {
            "id":          "string — uuid",
            "type":        "'food'",
            "name":        "string — nom de l'aliment",
            "foodId":      "string? — référence vers food-db.ref.json",
            "bags":        "FreezerBag[]",
            "_FreezerBag": {
              "id":          "string — uuid",
              "quantity":    "string — ATTENTION: actuellement string, cible = number",
              "unit":        "string — valeur de l'enum Unit ('g', 'kg', 'portion', etc.)",
              "preparation": "string? — ex: 'émincé', 'cuit à la vapeur'",
              "addedDate":   "string — date ISO YYYY-MM-DD"
            }
          },
          "_BatchFreezerItem": {
            "id":         "string — uuid",
            "type":       "'batch'",
            "recipeId":   "string — référence vers recipes-db.ref.json",
            "recipeName": "string — dupliqué depuis la recette (à supprimer dans type system cible)",
            "portions":   "number",
            "addedDate":  "string — date ISO YYYY-MM-DD"
          }
        }
      }
    }
  },

